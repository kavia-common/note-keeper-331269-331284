# Backend server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# SQLite database path (provided by the database container in this environment)
# IMPORTANT: do not hardcode; configure in .env
SQLITE_DB=/absolute/or/relative/path/to/notes.sqlite

# CORS (comma-separated lists)
# Frontend runs on :3000, backend on :3001 in preview/dev.
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization
CORS_MAX_AGE=3600
TRUST_PROXY=true
